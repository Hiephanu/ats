{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": ".",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "composite": true,
    "moduleDetection": "force",
    "baseUrl": "."
  },
  "include": ["src/**/*", "../../apps/match/src/libs/gemini.client.ts"],
  "exclude": ["node_modules", "dist"],
  "references": [
    { "path": "../../apps/match" }
  ]
}
