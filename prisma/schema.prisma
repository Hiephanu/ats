// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Skill {
  id                    String   @id @default(uuid())

  canonicalName         String   @map("canonical_name")
  normalizedCanonical   String   @unique @map("normalized_canonical")

  description           String?

  skillType             String?  @map("skill_type")
  reuseLevel            String?  @map("reuse_level")

  status                SkillStatus @default(PENDING)

  usageCount            Int @default(0) @map("usage_count")

  sourceId              String?  @map("source_id")
  isSystem              Boolean  @default(false) @map("is_system")

  mergeIntoId           String?  @map("merge_into_id")
  mergeInto             Skill?   @relation("SkillMerge", fields: [mergeIntoId], references: [id])
  mergedFrom            Skill[]  @relation("SkillMerge")

  createdById           String?  @map("created_by_id")

  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  outgoingRelations     SkillRelation[] @relation("FromSkill")
  incomingRelations     SkillRelation[] @relation("ToSkill")
  aliases               SkillAlias[]
  occupationSkills      OccupationSkill[]
  candidateSkills       CandidateSkill[]
  reviewLogs            SkillReviewLog[]
  mergedLogsFrom        SkillMergeLog[] @relation("SkillMergeFrom")
  mergedLogsTo          SkillMergeLog[] @relation("SkillMergeTo")

  @@index([normalizedCanonical])
  @@index([status])
  @@index([usageCount])
  @@map("skill")
}

model SkillAlias {
  id            String   @id @default(uuid())

  skillId       String   @map("skill_id")

  raw           String
  normalized    String

  source        String?
  confidence    Float?

  createdById   String?  @map("created_by_id")

  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  skill         Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@index([normalized])
  @@index([skillId])
  @@unique([skillId, normalized])

  @@map("skill_alias")
}

model SkillRelation {
  id            String   @id @default(uuid())

  fromSkillId   String   @map("from_skill_id")
  toSkillId     String   @map("to_skill_id")

  type          RelationType
  source        String?  // ESCO, CV, JOB...

  createdAt     DateTime @default(now()) @map("created_at")

  fromSkill     Skill @relation("FromSkill", fields: [fromSkillId], references: [id], onDelete: Cascade)
  toSkill       Skill @relation("ToSkill", fields: [toSkillId], references: [id], onDelete: Cascade)

  @@index([fromSkillId])
  @@index([toSkillId])

  @@unique([fromSkillId, toSkillId, type])

  @@map("skill_relation")
}

enum RelationType {
  PARENT        // broader
  CHILD         // narrower
  RELATED       // optional
  ESSENTIAL     // essential
}

model SkillReviewLog {

  id           String   @id @default(uuid())

  skillId      String
  skill        Skill    @relation(fields: [skillId], references: [id])

  action       SkillReviewAction @default(UPDATE)

  comment      String?

  oldValue     Json?
  newValue     Json?

  reviewedById String?

  createdAt    DateTime @default(now())

  @@index([skillId])
}

enum SkillStatus {
  PENDING
  APPROVED
  REJECTED
  ACTIVE
  INACTIVE
}

enum SkillReviewAction {
  UPDATE
  APPROVE
  REJECT
  ACTIVATE
  DEACTIVATE
}

model Occupation {
  id          String   @id @default(uuid())

  name        String
  description String?

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  occupationSkills OccupationSkill[]

  @@map("occupation")
}

model OccupationSkill {
  occupationId String  @map("occupation_id")
  skillId      String  @map("skill_id")

  weight       Float?
  isCore       Boolean @default(false) @map("is_core")

  createdAt    DateTime @default(now()) @map("created_at")

  occupation   Occupation @relation(fields: [occupationId], references: [id], onDelete: Cascade)
  skill        Skill      @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([occupationId, skillId])
  @@index([skillId])
  @@map("occupation_skill")
}

model Candidate {
  id        String   @id @default(uuid())

  fullName  String?  @map("full_name")
  email     String?  @unique

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  candidateSkills CandidateSkill[]

  @@map("candidate")
}

model CandidateSkill {
  id           String   @id @default(uuid())

  candidateId  String   @map("candidate_id")
  skillId      String   @map("skill_id")

  level        SkillLevel?
  years        Float?
  confidence   Float?

  source       String?

  createdAt    DateTime @default(now()) @map("created_at")

  candidate    Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  skill        Skill     @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([candidateId, skillId])
  @@index([skillId])
  @@map("candidate_skill")
}

enum SkillLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
  MASTER
}

model SkillMergeLog {
  id            String   @id @default(uuid())

  fromSkillId   String   @map("from_skill_id")
  toSkillId     String   @map("to_skill_id")

  mergedById    String?  @map("merged_by_id")

  createdAt     DateTime @default(now()) @map("created_at")

  fromSkill     Skill @relation("SkillMergeFrom", fields: [fromSkillId], references: [id])
  toSkill       Skill @relation("SkillMergeTo", fields: [toSkillId], references: [id])

  @@index([fromSkillId])
  @@index([toSkillId])

  @@map("skill_merge_log")
}


model ImportLog {
  id          String   @id @default(uuid())
  
  importedBy  String   @map("imported_by")      // ID của người import
  fileId      String   @map("file_id")          // ID của file được import
  type        String   @map("type")             // Kiểu import: SKILL | CANDIDATE | CV ...

  status      String   @default("PENDING")      // PENDING | RUNNING | COMPLETED | FAILED
  startedAt   DateTime @default(now()) @map("started_at")
  finishedAt  DateTime? @map("finished_at")

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([fileId])
  @@index([importedBy])
  @@index([type])

  @@map("import_log")  // đặt tên bảng camelCase
}
