// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Skill {
  id                   String   @id
  sourceId              String
  canonical             String
  normalizedCanonical   String   @unique

  skillType             String?
  reuseLevel            String?
  description           String?

  aliases               SkillAlias[]

  createdAt             DateTime @default(now())
}

model SkillAlias {
  id         Int     @id @default(autoincrement())
  skillId    String

  raw        String
  normalized String
  type       String

  skill      Skill   @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@index([normalized])
  @@index([skillId])
}
