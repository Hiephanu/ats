// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// 1. CANONICAL ENTITIES
// ==========================================

model Occupation {
  id                  String   @id @default(uuid())
  sourceId            String?  @map("source_id")
  canonicalName       String   @map("canonical_name")
  normalizedCanonical String   @unique @map("normalized_canonical")
  description         String?
  level               Int      @default(1)

  parentId            String?  @map("parent_id")
  parent              Occupation?  @relation("OccupationHierarchy", fields: [parentId], references: [id])
  children            Occupation[] @relation("OccupationHierarchy")

  aliases             OccupationAlias[]
  requiredSkills      OccupationSkill[]

  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@map("occupations")
}

model Skill {
  id                  String   @id @default(uuid())
  sourceId            String?  @map("source_id")
  canonicalName       String   @map("canonical_name")
  normalizedCanonical String   @unique @map("normalized_canonical")

  skillType           String?  @map("skill_type")
  reuseLevel          String?  @map("reuse_level")
  description         String?

  aliases             SkillAlias[]
  occupations         OccupationSkill[]

  createdAt           DateTime @default(now()) @map("created_at")

  @@map("skills")
}


// ==========================================
// 2. ALIAS TABLES
// ==========================================

model OccupationAlias {
  id           Int        @id @default(autoincrement())
  occupationId String     @map("occupation_id")
  raw          String
  normalized   String
  confidence   Float      @default(1.0)

  occupation   Occupation @relation(fields: [occupationId], references: [id], onDelete: Cascade)

  @@index([normalized])
  @@map("occupation_aliases")
}

model SkillAlias {
  id         Int      @id @default(autoincrement())
  skillId    String   @map("skill_id")
  raw        String
  normalized String

  skill      Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@index([normalized])
  @@map("skill_aliases")
}


// ==========================================
// 3. MANY-TO-MANY KNOWLEDGE MAP
// ==========================================

model OccupationSkill {
  occupationId String   @map("occupation_id")
  skillId      String   @map("skill_id")
  importance   Float    @default(0.5)
  isEssential  Boolean  @default(false) @map("is_essential")

  occupation   Occupation @relation(fields: [occupationId], references: [id])
  skill        Skill      @relation(fields: [skillId], references: [id])

  @@id([occupationId, skillId])
  @@map("occupation_skills")
}