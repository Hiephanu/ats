# Match Service Environment Variables

# Database
DATABASE_URL=postgresql://match:matchpassword@localhost:5432/match_db
POSTGRES_USER=match
POSTGRES_PASSWORD=matchpassword
POSTGRES_DB=match_db
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PORT=6379

# CV Queue
CV_QUEUE_CHANNEL=cv-processing
CV_UPLOAD_CHANNEL=cv-upload

# OCR Service
OCR_URL=http://localhost:9000

# Gemini AI
GEMINI_API_KEY=your_gemini_api_key_here

# Server
MATCH_PORT=3001
NODE_ENV=development

# AWS S3 (Optional)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
S3_BUCKET=ats-cvs

# Storage
STORAGE_PROVIDER=local
LOCAL_STORAGE_PATH=./storage
