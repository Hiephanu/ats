{
  "name": "ats",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "libraries/*"
  ],
  "scripts": {
    "dev:match": "npm run dev -w @ats/match",
    "dev:worker": "npm run dev -w @ats/worker",
    "dev:ocr": "npm run dev -w @ats/ocr-service",
    "dev:web": "npm run dev -w @ats/web",
    "dev:worker:send-fake-message": "npm run send-fake-message -w @ats/worker",
    "build": "npm run build -ws --if-present",
    "build:shared": "npm run build -w @ats/shared",
    "typecheck": "npm run typecheck -ws --if-present",
    "db:generate": "npm run db:generate -w @ats/match",
    "db:migrate": "npm run db:migrate -w @ats/match",
    "db:push": "npm run db:push -w @ats/match",
    "db:studio": "npm run db:studio -w @ats/match",
    "db:reset": "npm run db:migrate:dev -- --force && npm run db:seed -w @ats/match",
    "infra:dev:up": "docker compose -f infra/docker-compose.dev.yaml up -d",
    "infra:dev:down": "docker compose -f infra/docker-compose.dev.yaml down",
    "infra:logs": "docker compose logs -f",
    "infra:logs:ocr": "docker compose logs -f ocr",
    "clean": "rm -rf node_modules apps/*/node_modules libraries/*/node_modules"
  },
  "devDependencies": {
    "typescript": "^5.7.3"
  }
}