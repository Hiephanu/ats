{
  "name": "ats",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "libraries/*"
  ],
  "scripts": {
    "dev:match": "npm run dev -w @ats/match",
    "dev:match:upload-worker": "npm run dev:worker:upload -w @ats/match",
    "dev:match:process-worker": "npm run dev:worker:process -w @ats/match",
    "dev:match:workers": "npm run dev:workers -w @ats/match",
    "build": "npm run build -ws --if-present",
    "build:shared": "npm run build -w @ats/shared",
    "typecheck": "npm run typecheck -ws --if-present",
    "db:generate": "npm run db:generate -w @ats/match",
    "db:migrate": "npm run db:migrate -w @ats/match",
    "db:push": "npm run db:push -w @ats/match",
    "db:studio": "npm run db:studio -w @ats/match",
    "db:reset": "npm run db:migrate:dev -- --force && npm run db:seed -w @ats/match",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "infra:logs": "docker compose logs -f",
    "infra:logs:ocr": "docker compose logs -f ocr",
    "ocr:build": "docker compose build ocr",
    "ocr:start": "docker compose up -d ocr",
    "ocr:stop": "docker compose stop ocr",
    "clean": "rm -rf node_modules apps/*/node_modules libraries/*/node_modules"
  },
  "devDependencies": {
    "typescript": "^5.7.3"
  }
}